{
    "name": "labelforge/label-forge",
    "description": "AI Data Labeling Pipeline Service",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "slim/slim": "4.*",
        "slim/psr7": "^1.7",
        "slim/http": "^1.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "classmap": ["src/"]
    },
    "autoload-dev": {
        "psr-4": {
            "LabelForge\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit tests/"
    }
}
